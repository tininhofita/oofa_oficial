# Supabase — copie este arquivo para .env.local e preencha os valores

NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anonima_supabase

NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Chave secreta do Supabase (somente no servidor, nunca expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role

# Bling API
BLING_CLIENT_ID=seu_client_id_bling
BLING_CLIENT_SECRET=seu_client_secret_bling
BLING_WEBHOOK_SECRET=seu_webhook_secret_bling

# URL pública da aplicação (exibida como URL do webhook no painel)
NEXT_PUBLIC_APP_URL=https://seu-dominio.com

# NuvemShop API
NUVEMSHOP_CLIENT_ID=seu_client_id_nuvemshop
NUVEMSHOP_CLIENT_SECRET=seu_client_secret_nuvemshop
NUVEMSHOP_WEBHOOK_SECRET=seu_webhook_secret_nuvemshop

# Cron (segredo para proteger o endpoint de sync automático)
CRON_SECRET=seu_cron_secret
