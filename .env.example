# Supabase — copie este arquivo para .env.local e preencha os valores
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key-aqui

# Chave secreta do Supabase (somente no servidor, nunca expor no cliente)
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key-aqui

# Bling API
BLING_CLIENT_ID=
BLING_CLIENT_SECRET=
BLING_WEBHOOK_SECRET=

# NuvemShop API
NUVEMSHOP_CLIENT_ID=
NUVEMSHOP_CLIENT_SECRET=
NUVEMSHOP_WEBHOOK_SECRET=

# Cron (segredo para proteger o endpoint de sync automático)
CRON_SECRET=
